{
  "manifest_version": 3,
  "name": "Arin Grok Auto Flow",
  "version": "1.0",
  "description": "Auto Video on Grok - Arin Edition",
  "permissions": [
    "storage",
    "sidePanel",
    "scripting",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "*://grok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://grok.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "คลิกเพื่อเปิด Arin Grok Auto Flow"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js"
      ],
      "matches": [
        "https://grok.com/*"
      ]
    }
  ]
}